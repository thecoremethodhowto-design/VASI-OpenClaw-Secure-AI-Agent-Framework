TELEGRAM_BOT_TOKEN=Buraya_BotFather_Tokenini_Yazin
MY_TELEGRAM_ID=Buraya_Kendi_IDnizi_Yazin
WORKSPACE_DIR=/app/workspace
# Mac/host uzerinde zaten calisan Ollama icin:
OLLAMA_HOST=http://host.docker.internal:11434
VASI_NOTES_FILE=NOTES.md
VASI_CHANNEL_STYLE_FILE=channel_style.md
VASI_MODEL_GATEKEEPER=qwen3:30b
VASI_MODEL_STRATEJI=qwen3:30b
VASI_MODEL_TEKNIK=qwen3:30b
VASI_MODEL_KOD=qwen3-coder:30b
VASI_MODEL_GORSEL=qwen3:30b
GEMINI_API_KEY=Buraya_Gemini_API_Key_Yazin
GEMINI_MODEL=gemini-2.5-flash
# Opsiyonel: Web radar'ı sadece belirli domainlerde çalıştırmak için
# WEB_RADAR_ALLOWLIST=github.com,openai.com,ai.google.dev
PENDING_ACTION_TTL_SECONDS=600
GEMINI_DAILY_LIMIT_REQUESTS=60
# Istege bagli: Ollama guvenligi icin API Key
# OLLAMA_API_KEY=your-secret-key-here
